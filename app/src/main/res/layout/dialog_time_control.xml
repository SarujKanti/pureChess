<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏱  Time Control"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Each player's clock only ticks on their turn."
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="20dp" />

    <!-- 2×2 grid of time buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn5min"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_button_outline"
            android:text="5 min"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn10min"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_button_outline"
            android:text="10 min"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn20min"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_button_outline"
            android:text="20 min"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn30min"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_button_outline"
            android:text="30 min"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/bg_card_elevated"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/btnNoTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="No timer — unlimited time"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:padding="6dp" />

</LinearLayout>
