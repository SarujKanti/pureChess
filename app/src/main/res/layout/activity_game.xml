<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Top bar ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Back"
            android:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/txtModeLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="vs Computer"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDifficultyBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_button_outline"
            android:text="Lvl 5"
            android:textColor="@color/gold"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── Status (check / thinking) ──────────────────────────────────── -->
    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/check_red"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Top player card ─────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topPlayerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="2dp"
        android:background="@drawable/bg_player_card"
        app:layout_constraintTop_toBottomOf="@id/txtStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/dotTopTurn"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:background="#D4AF37"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/imgTopPlayer"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="♚"
            android:textSize="22sp"
            android:textColor="@color/text_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTopPlayerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Black"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTopCaptured"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtTopTurnLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR TURN"
            android:textColor="@color/gold"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:visibility="invisible" />
    </LinearLayout>

    <!-- ── Rank labels (left of board, aligned to boardContainer) ──────── -->
    <LinearLayout
        android:id="@+id/rankLabels"
        android:layout_width="18dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toTopOf="@id/boardContainer"
        app:layout_constraintBottom_toBottomOf="@id/boardContainer"
        app:layout_constraintStart_toStartOf="parent">

        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:gravity="center" android:text="8" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:gravity="center" android:text="7" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:gravity="center" android:text="6" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:gravity="center" android:text="5" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:gravity="center" android:text="4" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:gravity="center" android:text="3" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:gravity="center" android:text="2" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:gravity="center" android:text="1" android:textColor="#66B0B8D0" android:textSize="9sp" />
    </LinearLayout>

    <!-- ── Board container (truly square, between player cards) ─────────── -->
    <FrameLayout
        android:id="@+id/boardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_board_border"
        android:padding="3dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/topPlayerCard"
        app:layout_constraintBottom_toTopOf="@id/fileLabels"
        app:layout_constraintStart_toEndOf="@id/rankLabels"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintWidth_max="450dp">

        <GridLayout
            android:id="@+id/chessBoard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="8"
            android:rowCount="8" />
    </FrameLayout>

    <!-- ── File labels (below board) ───────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/fileLabels"
        android:layout_width="0dp"
        android:layout_height="16dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/bottomPlayerCard"
        app:layout_constraintStart_toEndOf="@id/rankLabels"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:text="a" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:text="b" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:text="c" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:text="d" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:text="e" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:text="f" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:text="g" android:textColor="#66B0B8D0" android:textSize="9sp" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:text="h" android:textColor="#66B0B8D0" android:textSize="9sp" />
    </LinearLayout>

    <!-- ── Bottom player card ──────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottomPlayerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_player_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/dotBottomTurn"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:background="#D4AF37"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/imgBottomPlayer"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="♔"
            android:textSize="22sp"
            android:textColor="@color/text_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtBottomPlayerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtBottomCaptured"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtBottomTurnLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR TURN"
            android:textColor="@color/gold"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:visibility="invisible" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
