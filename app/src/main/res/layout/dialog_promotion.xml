<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Promote Pawn"
        android:textColor="@color/gold"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnPromoteQueen"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_player_card"
            android:padding="6dp"
            android:contentDescription="Queen" />

        <ImageView
            android:id="@+id/btnPromoteRook"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_player_card"
            android:padding="6dp"
            android:contentDescription="Rook" />

        <ImageView
            android:id="@+id/btnPromoteBishop"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_player_card"
            android:padding="6dp"
            android:contentDescription="Bishop" />

        <ImageView
            android:id="@+id/btnPromoteKnight"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_player_card"
            android:padding="6dp"
            android:contentDescription="Knight" />
    </LinearLayout>
</LinearLayout>
