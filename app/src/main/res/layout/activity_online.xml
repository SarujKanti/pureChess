<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Back button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Back"
            android:tint="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Play Online"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Spacer -->
    <View android:layout_width="match_parent" android:layout_height="24dp" />

    <!-- Create room card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create a Room"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:text="Share the room code with your friend to start a game."
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Room code display (shown after creation) -->
        <LinearLayout
            android:id="@+id/roomCodeBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_difficulty_bar"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room Code"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtRoomCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="------"
                android:textColor="@color/gold"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="0.3" />

            <TextView
                android:id="@+id/txtWaitingOpponent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Waiting for opponent..."
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnCreateRoom"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_gold"
            android:text="Create Room"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Join room card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join a Room"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:text="Enter a 6-digit code to join your friend's game."
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etRoomCode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Enter room code"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:inputType="textCapCharacters|number"
            android:maxLength="6"
            android:gravity="center"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:background="@drawable/bg_difficulty_bar"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnJoinRoom"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_outline"
            android:text="Join Room"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Firebase notice -->
    <TextView
        android:id="@+id/txtFirebaseNotice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="Online play requires Firebase setup.\nSee README for instructions."
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
