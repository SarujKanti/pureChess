<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- ── Top app bar ──────────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBackSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/gold"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Settings"
                android:textColor="@color/gold"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.03" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22D4AF37" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Scrollable settings content ────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ══════════════ SOUND SECTION ══════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔊  SOUND"
                android:textColor="@color/gold"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp" />

            <!-- Master Sound Toggle -->
            <LinearLayout
                android:id="@+id/rowSoundMaster"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sound Effects"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable or mute all sounds"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchSoundMaster"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Individual sound toggles (inside a card, indented) -->
            <LinearLayout
                android:id="@+id/soundSubOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_card"
                android:padding="4dp">

                <!-- Move -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Move sound"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSoundMove"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Capture -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Capture sound"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSoundCapture"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Check warning -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Check warning"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSoundCheck"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Win/draw sound -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Win &amp; draw sound"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSoundWin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp"
                android:background="#1AFFFFFF" />

            <!-- ══════════════ BOARD THEME SECTION ════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎨  BOARD THEME"
                android:textColor="@color/gold"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp" />

            <!-- Board theme: 5+5 grid -->
            <LinearLayout
                android:id="@+id/boardThemeRow1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:id="@+id/boardThemeRow2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="4dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp"
                android:background="#1AFFFFFF" />

            <!-- ══════════════ PIECE STYLE SECTION ════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="♟  PIECE STYLE"
                android:textColor="@color/gold"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/pieceStyleRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="4dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp"
                android:background="#1AFFFFFF" />

            <!-- ══════════════ BACKGROUND SECTION ════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🖼  HOME BACKGROUND"
                android:textColor="@color/gold"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/bgThemeRow1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:id="@+id/bgThemeRow2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="4dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp"
                android:background="#1AFFFFFF" />

            <!-- ══════════════ APP THEME SECTION ══════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌙  APP THEME"
                android:textColor="@color/gold"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:weightSum="3">

                <LinearLayout
                    android:id="@+id/btnThemeSystem"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚙️" android:textSize="22sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="System" android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp" android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnThemeLight"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="☀️" android:textSize="22sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Light" android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp" android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnThemeDark"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌙" android:textSize="22sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Dark" android:textColor="?attr/colorOnSurface"
                        android:textSize="12sp" android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
