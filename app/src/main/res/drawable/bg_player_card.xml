<?xml version="1.0" encoding="utf-8"?>
<!--
  Player-card background — adapts to light/dark mode via @color/bg_card.
  Light:  near-white (#F8F9FF) with blue-gray border  → dark text visible
  Dark:   dark-navy  (#1E2538) with subtle border     → white text visible
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/bg_card" />
    <corners android:radius="10dp" />
    <stroke android:width="1dp" android:color="@color/bg_card_elevated" />
</shape>
