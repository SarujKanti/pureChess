<?xml version="1.0" encoding="utf-8"?>
<!--
  Used for difficulty bar, EditText fields (room code, player names), etc.
  Adapts to light/dark via @color/bg_card so hint/input text is always visible.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/bg_card" />
    <corners android:radius="8dp" />
    <stroke android:width="1dp" android:color="@color/bg_card_elevated" />
</shape>
